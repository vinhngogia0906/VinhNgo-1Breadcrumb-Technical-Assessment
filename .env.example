# Copy to .env to override defaults used by docker-compose.

POSTGRES_DB=librarydb
POSTGRES_USER=library
POSTGRES_PASSWORD=library
POSTGRES_PORT=5432

BACKEND_PORT=5000
FRONTEND_PORT=8080

# Must be at least 32 characters in production.
JWT_ISSUER=LibraryApi
JWT_AUDIENCE=LibraryApiClient
JWT_SIGNING_KEY=change-me-in-production-please-32-chars-min
JWT_EXPIRY_MINUTES=480

# Origin allowed by backend CORS (defaults to the frontend container URL).
FRONTEND_ORIGIN=http://localhost:8080

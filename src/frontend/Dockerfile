# syntax=docker/dockerfile:1.7
# Build context: src/frontend

FROM node:24-alpine AS build
WORKDIR /app

COPY package.json package-lock.json* ./
# Use `npm install` rather than `npm ci` so the build is resilient to lockfile
# drift caused by platform-specific optional dependencies (e.g. Rollup native
# binaries) that differ between Windows hosts and the Linux build container.
RUN npm install --no-audit --no-fund

COPY . .
RUN npm run build

FROM nginx:1.27-alpine AS runtime
COPY --from=build /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
